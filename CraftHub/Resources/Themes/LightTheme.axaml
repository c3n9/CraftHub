<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Corporate Light Theme Colors -->
    
    <!-- Backgrounds -->
    <SolidColorBrush x:Key="AppBackground" Color="#F8FAFC" />
    <SolidColorBrush x:Key="SurfaceBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ElevatedBackground" Color="#EFF2F6" />

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary" Color="#0F172A" />
    <SolidColorBrush x:Key="TextSecondary" Color="#475569" />
    <SolidColorBrush x:Key="TextMuted" Color="#94A3B8" />
    <SolidColorBrush x:Key="TextOnAccent" Color="#FFFFFF" />
    <SolidColorBrush x:Key="HighlightBackground" Color="#FFFDE68A" />
    <SolidColorBrush x:Key="HighlightForeground" Color="#0F172A" />

    <!-- Accents -->
    <SolidColorBrush x:Key="AccentPrimary" Color="#4F46E5" /> 
    <SolidColorBrush x:Key="AccentHover" Color="#6366F1" />
    <SolidColorBrush x:Key="AccentPressed" Color="#4338CA" />
    
    <!-- Semantic Colors -->
    <SolidColorBrush x:Key="SuccessColor" Color="#10B981" />
    <SolidColorBrush x:Key="WarningColor" Color="#F59E0B" />
    <SolidColorBrush x:Key="DangerColor" Color="#EF4444" />
    <SolidColorBrush x:Key="DangerHover" Color="#F87171" />

    <!-- Borders -->
    <SolidColorBrush x:Key="BorderColor" Color="#CBD5F5" />
    <SolidColorBrush x:Key="BorderLight" Color="#E2E8F0" />

</ResourceDictionary>
