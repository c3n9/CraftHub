<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Corporate Light Theme Colors -->
    
    <!-- Backgrounds -->
    <SolidColorBrush x:Key="AppBackground" Color="#F6F8FB" />
    <SolidColorBrush x:Key="SurfaceBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ElevatedBackground" Color="#F1F5FA" />

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary" Color="#0B1220" />
    <SolidColorBrush x:Key="TextSecondary" Color="#334155" />
    <SolidColorBrush x:Key="TextMuted" Color="#64748B" />
    <SolidColorBrush x:Key="TextOnAccent" Color="#FFFFFF" />
    <SolidColorBrush x:Key="HighlightBackground" Color="#FFFDE68A" />
    <SolidColorBrush x:Key="HighlightForeground" Color="#0F172A" />

    <!-- Accents -->
    <SolidColorBrush x:Key="AccentPrimary" Color="#2563EB" />
    <SolidColorBrush x:Key="AccentHover" Color="#1D4ED8" />
    <SolidColorBrush x:Key="AccentPressed" Color="#1E40AF" />
    
    <!-- Semantic Colors -->
    <SolidColorBrush x:Key="SuccessColor" Color="#16A34A" />
    <SolidColorBrush x:Key="WarningColor" Color="#D97706" />
    <SolidColorBrush x:Key="DangerColor" Color="#DC2626" />
    <SolidColorBrush x:Key="DangerHover" Color="#B91C1C" />

    <!-- Borders -->
    <SolidColorBrush x:Key="BorderColor" Color="#D6DCE8" />
    <SolidColorBrush x:Key="BorderLight" Color="#E9EDF5" />

</ResourceDictionary>
