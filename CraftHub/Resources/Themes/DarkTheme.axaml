<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Corporate Dark Theme Colors -->
    
    <!-- Backgrounds -->
    <SolidColorBrush x:Key="AppBackground" Color="#12121A" />
    <SolidColorBrush x:Key="SurfaceBackground" Color="#1E1E28" />
    <SolidColorBrush x:Key="ElevatedBackground" Color="#2A2A3E" />
    
    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF" />
    <SolidColorBrush x:Key="TextSecondary" Color="#A1A1AA" />
    <SolidColorBrush x:Key="TextMuted" Color="#71717A" />
    <SolidColorBrush x:Key="TextOnAccent" Color="#FFFFFF" />

    <!-- Accents -->
    <SolidColorBrush x:Key="AccentPrimary" Color="#4F46E5" /> <!-- Indigo -->
    <SolidColorBrush x:Key="AccentHover" Color="#6366F1" />
    <SolidColorBrush x:Key="AccentPressed" Color="#4338CA" />
    
    <!-- Semantic Colors -->
    <SolidColorBrush x:Key="SuccessColor" Color="#10B981" />
    <SolidColorBrush x:Key="WarningColor" Color="#F59E0B" />
    <SolidColorBrush x:Key="DangerColor" Color="#EF4444" />
    <SolidColorBrush x:Key="DangerHover" Color="#F87171" />

    <!-- Borders -->
    <SolidColorBrush x:Key="BorderColor" Color="#3F3F4E" />
    <SolidColorBrush x:Key="BorderLight" Color="#282838" />

</ResourceDictionary>
