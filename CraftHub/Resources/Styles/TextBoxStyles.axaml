<Styles xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style Selector="TextBox">
        <Setter Property="Background" Value="{DynamicResource SurfaceBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="CaretBrush" Value="{DynamicResource AccentPrimary}" />
        <Setter Property="ContextFlyout">
            <MenuFlyout>
                <MenuItem Header="{DynamicResource TbCut}"
                          Command="{Binding $parent[TextBox].Cut}"
                          InputGesture="Ctrl+X" />
                <MenuItem Header="{DynamicResource TbCopy}"
                          Command="{Binding $parent[TextBox].Copy}"
                          InputGesture="Ctrl+C" />
                <MenuItem Header="{DynamicResource TbPaste}"
                          Command="{Binding $parent[TextBox].Paste}"
                          InputGesture="Ctrl+V" />
                <Separator />
                <MenuItem Header="{DynamicResource TbSelectAll}"
                          Command="{Binding $parent[TextBox].SelectAll}"
                          InputGesture="Ctrl+A" />
            </MenuFlyout>
        </Setter>
    </Style>
    <Style Selector="TextBox:focus /template/ Border">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimary}" />
    </Style>
    <Style Selector="TextBox.json-editor">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>
    <Style Selector="TextBox.json-editor /template/ Border">
        <Setter Property="Background" Value="{DynamicResource ElevatedBackground}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="BoxShadow" Value="none" />
    </Style>
    <Style Selector="TextBox.json-editor:pointerover /template/ Border">
        <Setter Property="Background" Value="{DynamicResource ElevatedBackground}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="BoxShadow" Value="none" />
    </Style>
    <Style Selector="TextBox.json-editor:focus /template/ Border">
        <Setter Property="Background" Value="{DynamicResource ElevatedBackground}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="BoxShadow" Value="none" />
    </Style>
    <Style Selector="TextBox.json-editor:focus-within /template/ Border">
        <Setter Property="Background" Value="{DynamicResource ElevatedBackground}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="BoxShadow" Value="none" />
    </Style>

    <Style Selector="TextBox.grid-editor">
        <Setter Property="Background" Value="{DynamicResource SurfaceBackground}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="Margin" Value="6,4" />
        <Setter Property="MinHeight" Value="40" />
    </Style>

</Styles>
