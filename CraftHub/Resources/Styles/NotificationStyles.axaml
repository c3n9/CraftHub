<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="using:CraftHub.Models">

    <Style Selector="Border.notification-toast">
        <Setter Property="Background" Value="{DynamicResource ElevatedBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Width" Value="320" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="BoxShadow" Value="0 12 28 0 #1A000000" />
    </Style>

    <Style Selector="Border.notification-row">
        <Setter Property="Background" Value="{DynamicResource SurfaceBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style Selector="Border.notification-accent">
        <Setter Property="CornerRadius" Value="10,0,0,10" />
        <Setter Property="Margin" Value="0" />
    </Style>
    <!-- In rows the radius is smaller to match the container. -->
    <Style Selector="Border.notification-row Border.notification-accent">
        <Setter Property="CornerRadius" Value="8,0,0,8" />
    </Style>

    <Style Selector="TextBlock.notification-icon">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.notification-message">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    </Style>

    <Style Selector="TextBlock.notification-timestamp">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
    </Style>

    <Style Selector="Button.notification-close">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="6" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="MinWidth" Value="26" />
        <Setter Property="MinHeight" Value="26" />
    </Style>
    <Style Selector="Button.notification-close:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BorderLight}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    </Style>

    <!-- Toast spacing -->
    <Style Selector="Border.notification-toast TextBlock.notification-icon">
        <Setter Property="Margin" Value="12,10,10,10" />
    </Style>
    <Style Selector="Border.notification-toast TextBlock.notification-message">
        <Setter Property="Margin" Value="0,10,8,0" />
    </Style>
    <Style Selector="Border.notification-toast TextBlock.notification-timestamp">
        <Setter Property="Margin" Value="0,2,8,10" />
    </Style>
    <Style Selector="Border.notification-toast Button.notification-close">
        <Setter Property="Margin" Value="6,8,8,8" />
    </Style>

    <!-- History row spacing -->
    <Style Selector="Border.notification-row TextBlock.notification-icon">
        <Setter Property="Margin" Value="12,8,10,8" />
    </Style>
    <Style Selector="Border.notification-row TextBlock.notification-message">
        <Setter Property="Margin" Value="0,8,8,0" />
    </Style>
    <Style Selector="Border.notification-row TextBlock.notification-timestamp">
        <Setter Property="Margin" Value="0,2,8,8" />
    </Style>
    <Style Selector="Border.notification-row Button.notification-close">
        <Setter Property="Margin" Value="6,6,8,6" />
    </Style>
</Styles>
