<ResourceDictionary xmlns="https://github.com/avaloniaui"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!-- TextBox context menu -->
	<x:String x:Key="TbCut">Cut</x:String>
	<x:String x:Key="TbCopy">Copy</x:String>
	<x:String x:Key="TbPaste">Paste</x:String>
	<x:String x:Key="TbSelectAll">Select All</x:String>

	<!-- Toolbar – WorkspaceView -->
	<x:String x:Key="ImportJson">Import JSON</x:String>
	<x:String x:Key="ExportJson">Export JSON</x:String>
	<x:String x:Key="ImportClass">Import Class</x:String>
	<x:String x:Key="ExportClass">Export Class</x:String>
	<x:String x:Key="AddRowBtn">Row</x:String>
	<x:String x:Key="AddPropBtn">Property</x:String>
	<x:String x:Key="AddPropertyLabel">Add Property:</x:String>
	<x:String x:Key="AddPropertyBtn">+ Add</x:String>
	<x:String x:Key="SchemaHeader">Schema</x:String>
	<x:String x:Key="FieldsLabel">Fields:</x:String>

	<!-- Watermarks -->
	<x:String x:Key="SearchWatermark">Search by value...</x:String>
	<x:String x:Key="PropertyNameWatermark">Property name</x:String>

	<!-- Status bar -->
	<x:String x:Key="RowsStatusLabel">Rows:</x:String>
	<x:String x:Key="SelectedStatusLabel">Selected:</x:String>
	<x:String x:Key="SizeStatusLabel">Size:</x:String>

	<!-- Undo / Redo -->
	<x:String x:Key="UndoTip">Undo</x:String>
	<x:String x:Key="RedoTip">Redo</x:String>
	<x:String x:Key="UndoDescAddRow">Add row</x:String>
	<x:String x:Key="UndoDescRemoveRows">Remove {0} row(s)</x:String>
	<x:String x:Key="UndoDescDuplicateRows">Duplicate {0} row(s)</x:String>
	<x:String x:Key="UndoDescPasteRows">Paste {0} row(s)</x:String>
	<x:String x:Key="UndoDescEditCell">Edit '{0}'</x:String>
	<x:String x:Key="UndoDescAddProperty">Add property '{0}'</x:String>
	<x:String x:Key="UndoDescRemoveProperty">Remove property '{0}'</x:String>
	<x:String x:Key="UndoDescRenameProperty">Rename '{0}' → '{1}'</x:String>

	<!-- Tooltips – WorkspaceView -->
	<x:String x:Key="ImportJsonTip">Import data from JSON file</x:String>
	<x:String x:Key="ExportJsonTip">Export data to JSON file</x:String>
	<x:String x:Key="ImportClassTip">Import schema from C# class file</x:String>
	<x:String x:Key="ExportClassTip">Export schema as C# class file</x:String>
	<x:String x:Key="AddRowTip">Add new data row</x:String>
	<x:String x:Key="RemoveFieldTip">Remove field</x:String>
	<x:String x:Key="RenameFieldTip">Rename field</x:String>
	<x:String x:Key="AddPropertyTip">Add property</x:String>
	<x:String x:Key="SwitchToJsonBtn">JSON</x:String>
	<x:String x:Key="SwitchToTableBtn">Table</x:String>
	<x:String x:Key="SwitchToJsonTip">Switch to raw JSON editor</x:String>
	<x:String x:Key="SwitchToTableTip">Apply changes and switch to table view</x:String>
	<x:String x:Key="JsonAppliedMsg">JSON applied successfully</x:String>
	<x:String x:Key="InvalidJsonError">Invalid JSON</x:String>
	<x:String x:Key="PasteRowsFromClipboard">Paste rows from clipboard</x:String>
	<x:String x:Key="CutRowsAndSaveToClipboard">Cut selected rows and save to clipboard</x:String>
	<x:String x:Key="CtxCut">Cut</x:String>
	<x:String x:Key="CtxCopyArray">Copy as Array</x:String>
	<x:String x:Key="CtxCopyObjects">Copy as Objects</x:String>
	<x:String x:Key="CtxPaste">Paste</x:String>
	<x:String x:Key="CtxDuplicate">Duplicate to end</x:String>
	<x:String x:Key="CtxDuplicateAfter">Duplicate after</x:String>
	<x:String x:Key="CtxDelete">Delete</x:String>

	<!-- Tooltips – MainWindow -->
	<x:String x:Key="UpdateTip">Update</x:String>
	<x:String x:Key="NotificationsTip">Notifications</x:String>
	<x:String x:Key="ToggleThemeTip">Toggle Theme</x:String>
	<x:String x:Key="ToggleLanguageTip">Toggle Language</x:String>
	<x:String x:Key="AddWorkspaceTip">Add new workspace</x:String>

	<!-- MainWindow – notification panel -->
	<x:String x:Key="NotificationsTitle">Notifications</x:String>
	<x:String x:Key="NoNotificationsYet">No notifications yet</x:String>
	<x:String x:Key="PopupsOff">Popups off</x:String>
	<x:String x:Key="PopupsOn">Popups on</x:String>
	<x:String x:Key="ClearAll">Clear all</x:String>
	<x:String x:Key="RenameTab">Rename</x:String>

	<!-- DataGrid context menu -->
	<x:String x:Key="DuplicateRows">Duplicate Row(s)</x:String>
	<x:String x:Key="CopyRowsAsArray">Copy Row(s) as array to JSON</x:String>
	<x:String x:Key="CopyRowsAsObjects">Copy Row(s) as objects to JSON</x:String>
	<x:String x:Key="RemoveRows">Remove Row(s)</x:String>

	<!-- WorkspaceViewModel – warnings / dialogs -->
	<x:String x:Key="EnterPropertyName">Enter property name</x:String>
	<x:String x:Key="PropertyAlreadyExists">Property with this name already exists</x:String>
	<x:String x:Key="RemovePropertyTitle">Remove property</x:String>
	<x:String x:Key="RemovePropertyMsg">Remove '{0}' from the schema?</x:String>
	<x:String x:Key="PropertyAdded">Property '{0}' added</x:String>
	<x:String x:Key="PropertyRemoved">Property '{0}' removed</x:String>
	<x:String x:Key="RenamePropertyTitle">Rename property</x:String>
	<x:String x:Key="RenamePropertyPrompt">Enter a new name for this property.</x:String>
	<x:String x:Key="PropertyRenamed">Property '{0}' renamed to '{1}'</x:String>
	<x:String x:Key="RowAdded">Row added ({0} total)</x:String>
	<x:String x:Key="RowsDuplicatedMsg">{0} row(s) duplicated to bottom</x:String>
	<x:String x:Key="RowsCopiedMsg">{0} row(s) copied to clipboard as JSON</x:String>
	<x:String x:Key="RowsCutMsg">{0} row(s) cut and copied to clipboard as JSON</x:String>
	<x:String x:Key="RowsPasteMsg">{0} rows(s) inserted into the table</x:String>
	<x:String x:Key="RowsPasteErrorMsg">Something went wrong. Failed to insert JSON</x:String>
	<x:String x:Key="ImportTitle">Import</x:String>
	<x:String x:Key="ExportTitle">Export</x:String>
	<x:String x:Key="NoFieldsDetectedMsg">No fields detected in JSON file.</x:String>
	<x:String x:Key="AddPropsBeforeExport">Add properties before exporting.</x:String>
	<x:String x:Key="ImportedMsg">Imported {0} rows, {1} fields</x:String>
	<x:String x:Key="ImportTypeMismatchMsg">Cannot import: one or more fields have an incompatible type. Change the type or fix the data and try again.</x:String>
	<x:String x:Key="TabLimitReachedMsg">Tab limit ({0}) reached. Remaining files were not imported.</x:String>
	<x:String x:Key="ExportedMsg">Exported to {0}</x:String>
	<x:String x:Key="NoPropsFoundMsg">No properties found in the class file.</x:String>
	<x:String x:Key="SelectClassTitle">Select Class</x:String>
	<x:String x:Key="SelectClassMsg">Multiple classes found. Select one to import:</x:String>
	<x:String x:Key="ImportedClassMsg">Imported class '{0}' with {1} properties</x:String>
	<x:String x:Key="ExportedClassMsg">Exported class '{0}'</x:String>
	<x:String x:Key="RemoveRowTitle">Remove row</x:String>
	<x:String x:Key="RemoveRowMsg">Are you sure you want to remove this row?</x:String>
	<x:String x:Key="RemoveRowsTitle">Remove rows</x:String>
	<x:String x:Key="RemoveRowsMsg">Remove {0} selected row(s)?</x:String>
	<x:String x:Key="RowRemovedMsg">Row removed</x:String>
	<x:String x:Key="RowsRemovedMsg">Removed {0} row(s)</x:String>
	<x:String x:Key="WorkspaceNameEmpty">Workspace name can't be empty</x:String>
	<x:String x:Key="WorkspaceRenamedMsg">Workspace renamed to '{0}'</x:String>
	<x:String x:Key="RenameWorkspaceTitle">Rename workspace</x:String>
	<x:String x:Key="RenameWorkspacePrompt">Enter a new name for this tab.</x:String>
	<x:String x:Key="WorkspaceNameLabel">Workspace name</x:String>
	<x:String x:Key="UpdatedCellMsg">Updated '{0}'</x:String>
	<x:String x:Key="ClosingWarningTitle">Warning</x:String>
	<x:String x:Key="ClosingWarningMsg">Unsaved data will be lost. Are you sure you want to close?</x:String>
	<x:String x:Key="CloseWorkspaceErrorTitle">Cannot Close</x:String>
	<x:String x:Key="CloseWorkspaceErrorMsg">At least one workspace tab must remain open.</x:String>
	<x:String x:Key="CloseWorkspaceTitle">Close Tab</x:String>
	<x:String x:Key="CloseWorkspaceMsg">Close this tab? All unsaved data will be lost.</x:String>
	<x:String x:Key="ImportOverwriteTitle">Import</x:String>
	<x:String x:Key="ImportOverwriteMsg">This tab already has data. Importing will overwrite all rows and properties. Continue?</x:String>

	<!-- Dialog buttons -->
	<x:String x:Key="BtnOk">OK</x:String>
	<x:String x:Key="BtnCancel">Cancel</x:String>
	<x:String x:Key="BtnSave">Save</x:String>
	<x:String x:Key="BtnImport">Import</x:String>

	<!-- MainWindowViewModel – update / error dialogs -->
	<x:String x:Key="UpdateAvailableMsg">The new version is available now.</x:String>
	<x:String x:Key="NewVersionTitle">New version</x:String>
	<x:String x:Key="NewVersionConfirmMsg">Do you want to download the new version? Save all files before starting the installation.</x:String>
	<x:String x:Key="ErrorTitle">Error</x:String>
	<x:String x:Key="NoReleaseInfoMsg">No release information available</x:String>
	<x:String x:Key="UpdateCancelledTitle">Cancelled</x:String>
	<x:String x:Key="UpdateCancelledMsg">Update was cancelled by user</x:String>
	<x:String x:Key="UpdateFailedTitle">Update Failed</x:String>

</ResourceDictionary>
