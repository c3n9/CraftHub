<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CraftHub.ViewModels"
        xmlns:views="using:CraftHub.Views"
        x:Class="CraftHub.Views.MainWindow"
        Title="CraftHub — JSON Visual Editor"
        MinWidth="900" MinHeight="600"
        Width="1200" Height="750"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackground}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Title bar area -->
        <Border Grid.Row="0" Background="{DynamicResource ElevatedBackground}" Padding="16,10">
            <Grid ColumnDefinitions="Auto,*">
                <StackPanel Orientation="Horizontal" Spacing="10" Grid.Column="0">
                    <TextBlock Text="◆" FontSize="22" Foreground="{DynamicResource AccentPrimary}"
                               VerticalAlignment="Center" />
                    <TextBlock Text="CraftHub" FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
                    <TextBlock Text="JSON Visual Editor" FontSize="12"
                               Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"
                               Margin="8,2,0,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="10" Grid.Column="1" HorizontalAlignment="Right">
                    <Button Content="🌗" Classes="toolbar-btn" Command="{Binding ToggleThemeCommand}" ToolTip.Tip="Toggle Theme" FontSize="16" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content: current workspace -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBackground}" Margin="0">
            <ContentControl Content="{Binding SelectedWorkspace}">
                <ContentControl.DataTemplates>
                    <DataTemplate DataType="{x:Type vm:WorkspaceViewModel}">
                        <views:WorkspaceView />
                    </DataTemplate>
                </ContentControl.DataTemplates>
            </ContentControl>
        </Border>

        <!-- Bottom tab bar -->
        <Border Grid.Row="2" Background="{DynamicResource ElevatedBackground}" Padding="8,6"
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" Spacing="0">
                <ItemsControl ItemsSource="{Binding Workspaces}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="0" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:WorkspaceViewModel}">
                            <StackPanel Orientation="Horizontal">
                                <Button Classes="tab-btn"
                                        Classes.tab-active="{Binding IsActive}"
                                        Content="{Binding Header}"
                                        Command="{Binding $parent[Window].DataContext.SelectWorkspaceCommand}"
                                        CommandParameter="{Binding}" />
                                <Button Classes="close-tab"
                                        Content="✕"
                                        Command="{Binding CloseCommand}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button Classes="tab-add"
                        Content="+"
                        Command="{Binding AddWorkspaceCommand}"
                        ToolTip.Tip="Add new workspace" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
