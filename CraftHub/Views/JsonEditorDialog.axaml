<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CraftHub.ViewModels"
        xmlns:models="using:CraftHub.Models"
        xmlns:dg="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.DataGrid"
        xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        x:Class="CraftHub.Views.JsonEditorDialog"
        Title="Nested Object Editor"
        Width="700" Height="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackground}"
        x:DataType="vm:JsonEditorViewModel">
    
    <Grid RowDefinitions="Auto, *, Auto, Auto" Margin="10">
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,10">
            <TextBox Text="{Binding PropertyNameInput}" Watermark="New Field" Width="150" />
            <ComboBox ItemsSource="{Binding AvailableTypes}" SelectedItem="{Binding SelectedType}" Width="100" />
            <Button Command="{Binding AddPropertyCommand}" Classes="toolbar-btn">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <materialIcons:MaterialIcon Kind="PlusThick" Width="16" Height="16" />
                    <TextBlock Text="Prop" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
            <Button Command="{Binding AddRowCommand}" Classes="toolbar-btn" IsVisible="{Binding !IsObjectMode}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <materialIcons:MaterialIcon Kind="TableRowPlusAfter" Width="16" Height="16" />
                    <TextBlock Text="Row" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </StackPanel>

        <DataGrid Grid.Row="1" x:Name="NestedDataGrid"
                     ItemsSource="{Binding Rows}"
                     AutoGenerateColumns="False" CanUserReorderColumns="True"
                     CanUserResizeColumns="True"
                     Background="{DynamicResource ElevatedBackground}"
                     RowBackground="{DynamicResource SurfaceBackground}"/>

        <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto" Margin="0,8">
            <ItemsControl ItemsSource="{Binding Properties}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="4" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:JsonPropertyDefinition}">
                        <Border Background="{DynamicResource ElevatedBackground}" CornerRadius="4" Padding="6,2"
                                BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextSecondary}" FontSize="12" />
                                <Button Content="{materialIcons:MaterialIconExt Kind=CloseThick}" Classes="close-tab" Command="{Binding $parent[Window].DataContext.RemovePropertyCommand}" CommandParameter="{Binding}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="Cancel" Command="{Binding CancelCommand}" Width="80" HorizontalContentAlignment="Center" />
            <Button Content="Save" Command="{Binding SubmitCommand}" Width="80" Classes="accent-btn" HorizontalContentAlignment="Center" />
        </StackPanel>
    </Grid>
</Window>
