<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CraftHub.ViewModels"
        xmlns:models="using:CraftHub.Models"
        x:Class="CraftHub.Views.JsonFieldMappingDialog"
        Title="Import JSON — Field Type Mapping"
        Width="650" Height="500"
        WindowStartupLocation="CenterOwner"
        Background="#16162a"
        CanResize="False">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Border Grid.Row="0" Background="#1e1e32" Padding="20,16">
            <StackPanel Spacing="4">
                <TextBlock Text="Configure Field Types"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="White" />
                <TextBlock Text="Select the data type for each detected JSON field."
                           FontSize="13" Foreground="#6666aa" />
            </StackPanel>
        </Border>

        <!-- Fields list -->
        <ScrollViewer Grid.Row="1" Padding="16,8">
            <ItemsControl ItemsSource="{Binding Fields}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:JsonFieldMapping}">
                        <Border Background="#1e1e32" CornerRadius="8"
                                Padding="16,12" Margin="0,4">
                            <Grid ColumnDefinitions="*,Auto,Auto">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding FieldName}"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="White" />
                                    <TextBlock FontSize="12" Foreground="#666680">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="Sample: {0}">
                                                <Binding Path="SampleValue" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>

                                <TextBlock Grid.Column="1"
                                           VerticalAlignment="Center"
                                           Margin="12,0"
                                           FontSize="12" Foreground="#555570">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="detected: {0}">
                                            <Binding Path="DetectedType" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>

                                <ComboBox Grid.Column="2"
                                          ItemsSource="{Binding $parent[Window].DataContext.AvailableTypes}"
                                          SelectedItem="{Binding SelectedType}"
                                          Width="130" FontSize="13"
                                          CornerRadius="6"
                                          VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer buttons -->
        <Border Grid.Row="2" Background="#1a1a2e" Padding="16,12"
                BorderBrush="#2a2a3e" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                <Button Content="Cancel" Classes="toolbar-btn"
                        x:Name="CancelButton" MinWidth="80" />
                <Button Content="Import" Classes="accent-btn"
                        x:Name="ConfirmButton" MinWidth="80" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
